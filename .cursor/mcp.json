{
  "mcpServers": {
    "Sentry": {
      "url": "https://mcp.sentry.dev/mcp",
      "headers": {}
    },
    "playwright": {
      "command": "bunx",
      "args": ["@playwright/mcp@latest"]
    },
    "better-auth": {
      "url": "https://mcp.better-auth.com/mcp"
    },
    "shadcn": {
      "command": "bunx",
      "args": ["shadcn@latest", "mcp"]
    },
    "next-devtools": {
      "command": "bunx",
      "args": ["-y", "next-devtools-mcp@latest"]
    },
    "Astro docs": {
      "url": "https://mcp.docs.astro.build/mcp",
      "headers": {}
    }
  }
}

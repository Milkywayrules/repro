{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "apps/marketing/Dockerfile",
    "watchPatterns": [
      "/apps/marketing/**",
      "/apps/marketing/Dockerfile",
      "/apps/marketing/nginx.conf",
      "/packages/env/**",
      "/packages/config/**",
      "/infra/railway/marketing.json",
      "/package.json",
      "/bun.lock",
      "/turbo.json"
    ]
  },
  "deploy": {
    "healthcheckPath": "/",
    "healthcheckTimeout": 60,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5,
    "drainingSeconds": 5,
    "overlapSeconds": 10,
    "multiRegionConfig": {
      "asia-southeast1-eqsg3a": {
        "numReplicas": 1
      }
    }
  }
}

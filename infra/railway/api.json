{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "apps/api/Dockerfile",
    "watchPatterns": [
      "/apps/api/**",
      "/apps/api/Dockerfile",

      "/packages/auth/**",
      "/packages/db/**",
      "/packages/env/**",
      "/packages/ui/**",
      "/packages/config/**",

      "/infra/railway/api.json",
      "/package.json",
      "/bun.lock",
      "/turbo.json"
    ]
  },
  "deploy": {
    "startCommand": "./server",
    "preDeployCommand": ["./migrate"],
    "healthcheckPath": "/ready",
    "healthcheckTimeout": 120,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5,
    "drainingSeconds": 20,
    "overlapSeconds": 30,
    "multiRegionConfig": {
      "asia-southeast1-eqsg3a": {
        "numReplicas": 1
      }
    }
  }
}

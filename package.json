{
  "name": "repro",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "@types/bun": "^1.3.4",
      "better-auth": "1.6.11",
      "evlog": "^2.18.1",
      "next-themes": "^0.4.6",
      "react": "^19.2.6",
      "react-dom": "^19.2.6",
      "@types/react": "^19.2.15",
      "@types/react-dom": "^19.2.3"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @repro/db db:push",
    "db:studio": "turbo -F @repro/db db:studio",
    "db:generate": "turbo -F @repro/db db:generate",
    "db:migrate": "turbo -F @repro/db db:migrate",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "dependencies": {
    "@repro/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@repro/config": "workspace:*",
    "@types/bun": "catalog:",
    "lefthook": "latest",
    "turbo": "^2.9.16",
    "typescript": "catalog:",
    "ultracite": "7.8.3"
  },
  "packageManager": "bun@1.3.14"
}

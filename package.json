{
  "name": "repro",
  "private": true,
  "workspaces": {
    "packages": ["apps/*", "packages/*"],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "@types/bun": "^1.3.4",
      "better-auth": "1.6.11",
      "evlog": "^2.18.1",
      "next-themes": "^0.4.6",
      "react": "^19.2.6",
      "react-dom": "^19.2.6",
      "@types/react": "^19.2.15",
      "@types/react-dom": "^19.2.3"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:console": "turbo -F console dev",
    "dev:api": "turbo -F api dev",
    "dev:marketing": "turbo -F marketing dev",
    "dev:docs": "turbo -F docs dev",
    "db:push": "turbo -F @repro/db db:push",
    "db:studio": "turbo -F @repro/db db:studio",
    "db:generate": "turbo -F @repro/db db:generate",
    "db:migrate": "bun run packages/db/src/migrate.ts",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "setup:local": "bash scripts/setup-local.sh",
    "sync:local-infra": "bun scripts/sync-local-infra.ts",
    "configure-product": "bun scripts/configure-product.ts",
    "postinstall": "bash scripts/postinstall.sh"
  },
  "dependencies": {
    "@repro/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@repro/config": "workspace:*",
    "@types/bun": "catalog:",
    "lefthook": "latest",
    "turbo": "^2.9.16",
    "typescript": "catalog:",
    "ultracite": "7.8.3"
  },
  "packageManager": "bun@1.3.14"
}

{
  "name": "docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build:docker": "docker build -f Dockerfile -t repro-docs ../..",
    "build": "bun next build",
    "build:staging": "bun --env-file=.env.staging next build",
    "dev": "bun run ./scripts/dev.ts",
    "start": "bun --bun next start",
    "check-types": "fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "fumadocs-mdx",
    "lint": "biome check",
    "format": "biome format --write"
  },
  "dependencies": {
    "@repro/env": "workspace:*",
    "@takumi-rs/image-response": "^1.7.0",
    "fumadocs-core": "16.10.0",
    "fumadocs-mdx": "15.0.12",
    "fumadocs-ui": "16.10.0",
    "lucide-react": "^1.17.0",
    "next": "16.2.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3"
  }
}

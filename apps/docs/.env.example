# Docs — required. URLs derive from APP_ENV + DEPLOY_PLATFORM (@repro/env/docs).
# PORT here is the single source — `dev.ts` reads it via @repro/env/docs (Next.js ignores PORT in .env for dev bind).
#
# Mode files (committed, no secrets):
#   .env.development  — local dev (`bun run dev`)
#   .env.staging      — staging build (`bun run build:staging`)
#   .env.production   — production build (`bun run build`)

PORT=5009
APP_ENV=dev
DEPLOY_PLATFORM=local

# DEPLOY_PLATFORM=custom — required when deploying to arbitrary hosting (no shared base domain)
# DEPLOY_PLATFORM=custom
# API_URL=https://api-abc123.railway.app
# CONSOLE_URL=https://console-abc123.railway.app
# DOCS_URL=https://docs-abc123.railway.app
# MARKETING_URL=https://marketing-abc123.railway.app

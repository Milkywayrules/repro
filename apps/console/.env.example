# Console — required. URLs derive from VITE_APP_ENV + VITE_DEPLOY_PLATFORM.

PORT=5001
VITE_APP_ENV=dev
VITE_DEPLOY_PLATFORM=local

# VITE_DEPLOY_PLATFORM=custom — required when deploying to arbitrary hosting (no shared base domain)
# VITE_DEPLOY_PLATFORM=custom
# VITE_API_URL=https://api-abc123.railway.app
# VITE_CONSOLE_URL=https://console-abc123.railway.app
# VITE_DOCS_URL=https://docs-abc123.railway.app
# VITE_MARKETING_URL=https://marketing-abc123.railway.app

# Marketing — required. URLs derive from APP_ENV + DEPLOY_PLATFORM (@repro/env/marketing).

PORT=5002
APP_ENV=dev
DEPLOY_PLATFORM=local

# DEPLOY_PLATFORM=custom — required when deploying to arbitrary hosting (no shared base domain)
# DEPLOY_PLATFORM=custom

{
  "name": "api",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build:tsdown": "tsdown",
    "start:tsdown": "bun run dist/index.mjs",
    "check-types": "tsc --noEmit",
    "build:docker": "docker build -f Dockerfile -t repro-api ../..",
    "build": "bun build --compile --minify-whitespace --minify-syntax --target bun --outfile ./dist/server ./src/index.ts",
    "dev": "bun run --hot src/index.ts",
    "start": "./dist/server"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@repro/auth": "workspace:*",
    "@repro/db": "workspace:*",
    "@repro/env": "workspace:*",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "elysia": "^1.4.28",
    "evlog": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@repro/config": "workspace:*",
    "@types/bun": "catalog:",
    "tsdown": "^0.21.9",
    "typescript": "catalog:"
  }
}
